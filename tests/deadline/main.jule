use "std/net"
use "std/sync"
use "std/sync/atomic"
use "std/time"

async fn switchToEarlierDeadline() {
	mut x := new(int)
	mut conn := net::DialTimeout(net::Network.UDP, "10.255.255.1:8080", 1*time::Second).await!
	conn.SetReadDeadline(60 * time::Second)!
	mut wg := sync::WaitGroup.New()
	mut cond := sync::Cond.New(new(sync::Mutex))
	wg.Add(1)
	co async fn() {
		cond.Lock().await
		*x = 1
		cond.Signal()
		cond.Unlock()
		conn.Read(make([]byte, 128)).await else {
			wg.Done()
			return
		}
		panic("expected timeout error")
	}()
	cond.Lock().await
	for *x != 1 {
		cond.Wait().await
	}
	cond.Unlock()
	mut timestamp := time::Instant.Now()
	conn.SetReadDeadline(1 * time::Second)!
	wg.Wait().await
	mut elapsed := timestamp.Since()
	if elapsed < 1*time::Second {
		panic("deadline timer fired earlier than expected")
	}
	if elapsed > 2*time::Second {
		panic("deadline timer fired too late than expected")
	}
	// We expect timeout error.
	conn.Read(make([]byte, 128)).await else {
		goto Good
	}
	panic("expected timeout error")
Good:
	// Test with a clear deadline after timeout.
	conn.SetReadDeadline(1 * time::Second)!
	timestamp = time::Instant.Now()
	conn.Read(make([]byte, 128)).await else {
		elapsed = timestamp.Since()
		if elapsed < 1*time::Second {
			panic("deadline timer fired earlier than expected")
		}
		if elapsed > 2*time::Second {
			panic("deadline timer fired too late than expected")
		}
		return
	}
	panic("expected timeout error")
}

async fn switchToLaterDeadline() {
	mut x := new(int)
	mut conn := net::DialTimeout(net::Network.UDP, "10.255.255.1:8080", 1*time::Second).await!
	// Initial deadline is really small but no problem.
	// Read call will block anyway, then out main coroutine should continue to run.
	// Because condition variable will be signaled.
	// So we know read deadline will not be triggered before main coroutine run.
	// Scheduler will look for coroutines first.
	conn.SetReadDeadline(1 * time::Millisecond)!
	mut wg := sync::WaitGroup.New()
	mut cond := sync::Cond.New(new(sync::Mutex))
	wg.Add(1)
	co async fn() {
		cond.Lock().await
		*x = 1
		cond.Signal()
		cond.Unlock()
		conn.Read(make([]byte, 128)).await else {
			wg.Done()
			return
		}
		panic("expected timeout error")
	}()
	cond.Lock().await
	for *x != 1 {
		cond.Wait().await
	}
	cond.Unlock()
	mut timestamp := time::Instant.Now()
	conn.SetReadDeadline(1 * time::Second)!
	wg.Wait().await
	mut elapsed := timestamp.Since()
	if elapsed < 1*time::Second {
		panic("deadline timer fired earlier than expected")
	}
	if elapsed > 2*time::Second {
		panic("deadline timer fired too late than expected")
	}
	// We expect timeout error.
	conn.Read(make([]byte, 128)).await else {
		return
	}
	panic("expected timeout error")
}

async fn main() {
	switchToEarlierDeadline().await
	switchToLaterDeadline().await
}