use "std/sync/atomic"
use "std/time"

async fn checkTiming() {
	mut x := new(int)
	co async fn() {
		time::Sleep(1 * time::Millisecond).await
		atomic::Store(&*x, 1, atomic::Release)
	}()
	time::Sleep(2 * time::Millisecond).await
	if atomic::Load(&*x, atomic::Acquire) != 1 {
		panic("coroutine runs before earlier timer")
	}
}

async fn checkDuration() {
	timestamp := time::Instant.Now()
	time::Sleep(10 * time::Nanosecond).await
	elapsed := timestamp.Since()
	if elapsed < 10*time::Nanosecond {
		panic("sleep timer fired earlier than expected")
	}
}

async fn main() {
	checkTiming().await
	checkDuration().await
}