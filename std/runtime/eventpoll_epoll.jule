// TODO: consider io_uring backend for Linux once the runtime I/O abstraction is finalized.
// Currently deferred due to portability and stability concerns.

#build linux

use "std/internal/runtime/atomic"
use "std/internal/runtime/syscall"
use "std/mem"
use "std/sys"

extern use "<sys/epoll.h>"

let mut epfd: i32 = -1

let mut eventpollEventFd: uintptr = 0 // eventfd for eventpollBreak
let mut eventpollWakeSig: u32 = 0     // used to avoid duplicate calls of eventpollBreak

fn eventpollinit() {
	(epfd), mut errno := syscall_EpollCreate1(sys::EPOLL_CLOEXEC)
	if errno != _NO_ERROR {
		panic("runtime: epoll init failed")
	}
	efd, errno := syscall_Eventfd(0, sys::EFD_CLOEXEC|sys::EFD_NONBLOCK)
	if errno != _NO_ERROR {
		println("runtime: eventfd failed with " + errno.String())
		panic("runtime: eventfd failed")
	}
	let mut ev: epollEvent
	ev.events = sys::EPOLLIN
	ev.data._u64 = u64(uintptr(&eventpollEventFd))
	errno = syscall_EpollCtl(epfd, sys::EPOLL_CTL_ADD, efd, &ev)
	if errno != _NO_ERROR {
		println("runtime: epollctl failed with " + errno.String())
		panic("runtime: epollctl failed")
	}
	eventpollEventFd = uintptr(efd)
}

#disable nilptr boundary
fn eventpollopen(fd: u64, mut &pd: *polldesc)! {
	let mut ev: epollEvent
	ev.events = sys::EPOLLIN | sys::EPOLLOUT | sys::EPOLLRDHUP | sys::EPOLLET
	fdseq := atomic::Load(&pd.fdseq, atomic::Acquire)
	tp := taggedPointerPack(pd, fdseq)
	ev.data._u64 = u64(tp)
	e := syscall_EpollCtl(epfd, sys::EPOLL_CTL_ADD, i32(fd), &ev)
	if e != _NO_ERROR {
		throw sys::GetLastErrno()
	}
}

fn eventpollclose(fd: u64): sys::Errno {
	let mut ev: epollEvent
	return syscall_EpollCtl(epfd, sys::EPOLL_CTL_DEL, i32(fd), &ev)
}

// Interrupts an epollwait.
fn eventpollBreak() {
	// Failing to cas indicates there is an in-flight wakeup, so we're done here.
	if !atomic::CompareAndSwap(&eventpollWakeSig, 0, 1, atomic::AcqRel, atomic::AcqRel) {
		return
	}

	let mut one: u64 = 1
	oneSize := i32(mem::SizeOf(one))
	for {
		n, e := syscall_Write(eventpollEventFd, &one, oneSize)
		if n == oneSize {
			break
		}
		if e == sys::EINTR {
			continue
		}
		if e == sys::EAGAIN {
			return
		}
		println("runtime: eventpollBreak write failed with " + e.String())
		panic("runtime: eventpollBreak write failed")
	}
}

// delay < 0: blocks indefinitely
// delay == 0: does not block, just polls
// delay > 0: block for up to that many nanoseconds
#disable nilptr boundary
fn eventpoll(delay: i64, mut &toRun: *[prunqsize]c): u32 {
	if epfd == -1 {
		return 0
	}
	let mut wait: i32
	if delay < 0 {
		wait = -1
	} else if delay == 0 {
		wait = 0
	} else if delay < 1e6 {
		wait = 1
	} else if delay < 1e15 {
		// Convert delay to milliseconds, rounding *up* instead of truncating.
		//
		// This computation implements a ceiling division without using floating-point:
		//	wait = ceil(delay / 1ms)
		// which is equivalent to:
		//	(delay + 1ms - 1) / 1ms
		//
		// Rounding up is critical:
		//	- It guarantees that the timer never fires *earlier* than requested.
		//	- Early wakeups break scheduler semantics and can cause subtle race bugs.
		//
		// Any delay smaller than 1ms is clamped to 1ms intentionally.
		// This is NOT a loss of precision but a correctness requirement.
		//
		// Therefore, enforcing a minimum wait of 1ms preserves correctness,
		// avoids spin loops, and aligns with real OS timer granularity.
		wait = i32((delay + _Millisecond - 1) / _Millisecond)
	} else {
		// An arbitrary cap on how long to wait for a timer.
		// 1e9 ms == ~11.5 days.
		wait = 1e9
	}
	let mut events: [128]epollEvent
retry:
	n, errno := syscall_EpollWait(epfd, &events[0], i32(len(events)), wait)
	if errno != _NO_ERROR {
		if errno != sys::EINTR {
			panic("runtime: eventpoll: epoll failed")
		}
		// If a timed sleep was interrupted, just return to
		// recalculate how long we should sleep now.
		if wait >= 0 {
			return 0
		}
		goto retry
	}
	mut i := i32(0)
	mut b := u32(0)
	for i < n; i++ {
		&ev := &events[i]
		if ev.events == 0 {
			continue
		}

		if ev.data._u64 == u64(uintptr(&eventpollEventFd)) {
			if ev.events != sys::EPOLLIN {
				println("runtime: eventpoll: eventfd ready for non EPOLLIN")
				panic("runtime: eventpoll: eventfd ready for something unexpected")
			}
			if delay != 0 {
				// eventpollBreak could be picked up by a
				// nonblocking poll. Only read the 8-byte
				// integer if blocking.
				// Since EFD_SEMAPHORE was not specified,
				// the eventfd counter will be reset to 0.
				let mut one: u64
				syscall_Read(eventpollEventFd, &one, i32(mem::SizeOf(one)))
				atomic::Store(&eventpollWakeSig, 0, atomic::Release)
			}
			continue
		}

		let mut mode: i32
		if ev.events&(sys::EPOLLIN|sys::EPOLLRDHUP|sys::EPOLLHUP|sys::EPOLLERR) != 0 {
			mode += 'r'
		}
		if ev.events&(sys::EPOLLOUT|sys::EPOLLHUP|sys::EPOLLERR) != 0 {
			mode += 'w'
		}
		if mode == 0 {
			continue
		}
		tp := taggedPointer(ev.data._u64)
		mut &pd := unsafe { &(*(*polldesc)(tp.pointer())) }
		tag := tp.tag()
		if atomic::Load(&pd.fdseq, atomic::Acquire) != tag {
			continue // stale
		}
		pd.setEventErr(ev.events == sys::EPOLLERR, tag)
		eventpollready(pd, mode, toRun, &b)
	}
	return b
}