use "std/internal/runtime/atomic"

// Represents a scheduled event.
// when is an absolute timestamp in nanoseconds.
struct timer {
	mu:    mutex
	heap:  &timers                        // Owner timers.
	ifunc: fn(arg: uintptr, seq: uintptr) // Callback function to invoke when the timer fires.
	arg:   uintptr                        // Argument to pass to the callback function.
	seq:   uintptr                        // Sequence value to pass to the callback function.
	when:  i64                            // Absolute timestamp in nanoseconds indicating when the timer should fire.
	index: int                            // Heap index. Remains -1 if not currently in a heap.

	// Lock-free flag for lazy deletion.
	// Enables O(1) stop().
	deleted: i32
}

impl timer {
	// Creates and returns a new timer.
	#disable nilptr
	fn new(when: i64, ifunc: fn(arg: uintptr, seq: uintptr), arg: uintptr, seq: uintptr): &timer {
		mut t := new(timer)
		t.when = when
		t.ifunc = ifunc
		t.arg = arg
		t.seq = seq
		return t
	}

	// Modifies an existing timer.
	// Safe for concurrent use.
	#disable nilptr
	fn modify(mut &self, when: i64, ifunc: fn(arg: uintptr, seq: uintptr), arg: uintptr, seq: uintptr) {
		// The lock hierarchy (Lock Order) must be strictly enforced:
		//	Heap first, then timer.
		// This prevents deadlocks during concurrent modifications.
		if self.heap != nil {
			self.heap.mu.lock()
		}

		self.mu.lock()
		defer { self.mu.unlock() }

		self.when = when
		self.arg = arg
		self.seq = seq
		self.ifunc = ifunc

		// Reactivate the timer in case it was previously deleted via stop()
		// but not yet popped from the heap.
		atomic::Store(&self.deleted, 0, atomic::Release)

		if self.heap != nil && self.index != -1 {
			self.heap.siftdown(self.index)
			self.heap.siftup(self.index)
			// Update the atomic indicator since the heap root might have changed.
			self.heap.updateEarliest()
		}

		if self.heap != nil {
			self.heap.mu.unlock()
		} else {
			// We need to add this timer to a heap.
			self.addHeap()
		}
	}

	#disable nilptr
	fn addHeap(mut &self) {
		mut m := gett()
		m.pp.timers.push(self)
	}

	// Stops the timer.
	#disable nilptr
	fn stop(mut *self) {
		atomic::Store(&self.deleted, 1, atomic::Release)
	}

	// Fires the timer, which is runtime timer associated with a raw function.
	#disable nilptr
	fn unlockAndFire(mut *self) {
		arg := self.arg
		seq := self.seq
		ifunc := self.ifunc
		self.ifunc = nil
		self.mu.unlock()
		ifunc(arg, seq)
	}
}

// A min-heap ordered by [timer.when].
struct timers {
	mu:   mutex
	heap: []&timer

	// Atomically stores the execution time of the timer at the root of the heap.
	// This allows wakeTime to operate completely lock-free.
	earliest: i64
}

impl timers {
	// Updates the 'when' value of the heap root for lock-free operations.
	// Must be called while self.mu is locked, typically after heap manipulations.
	#disable nilptr boundary
	fn updateEarliest(mut *self) {
		if len(self.heap) > 0 {
			atomic::Store(&self.earliest, self.heap[0].when, atomic::Release)
		} else {
			// Indicates the heap is empty.
			atomic::Store(&self.earliest, -1, atomic::Release)
		}
	}

	// Inserts a timer into the heap.
	#disable nilptr
	fn push(mut *self, mut t: &timer) {
		self.mu.lock()
		defer { self.mu.unlock() }

		t.heap = unsafe { (&timers)(self) } // Never deallocated, so it is safe.
		t.index = len(self.heap)
		self.heap = append(self.heap, t)
		self.siftup(t.index)
		self.updateEarliest()
	}

	// Removes and returns the earliest timer.
	// self.mu must be locked before calling.
	#disable nilptr boundary
	fn pop(mut *self): &timer {
		n := len(self.heap)
		if n == 0 {
			return nil
		}

		mut min := self.heap[0]
		mut last := self.heap[n-1]

		self.heap = self.heap[:n-1]
		if n > 1 {
			self.heap[0] = last
			last.index = 0
			self.siftdown(0)
		}

		min.heap = nil
		min.index = -1
		self.updateEarliest()
		return min
	}

	// Deletes a specific timer from the heap regardless of its position.
	#disable nilptr boundary
	fn remove(mut *self, mut t: &timer) {
		self.mu.lock()
		defer { self.mu.unlock() }

		i := t.index
		if i < 0 || i >= len(self.heap) {
			return
		}

		mut last := self.heap[len(self.heap)-1]
		self.heap = self.heap[:len(self.heap)-1]

		if i != len(self.heap) {
			self.heap[i] = last
			last.index = i
			self.siftdown(i)
			self.siftup(i)
		}

		t.index = -1
		self.updateEarliest()
	}

	// Moves the timer at index i up the heap to restore the min-heap property.
	#disable nilptr boundary
	fn siftup(mut *self, mut i: int) {
		for {
			parent := (i - 1) / 2
			if i == 0 || cmpwhen(self.heap[parent].when, self.heap[i].when) <= 0 {
				break
			}
			self.swap(i, parent)
			i = parent
		}
	}

	// Moves the timer at index i down the heap to restore the min-heap property.
	#disable nilptr boundary
	fn siftdown(mut *self, mut i: int) {
		n := len(self.heap)
		for {
			left := 2*i + 1
			if left >= n {
				break
			}

			mut smallest := left
			right := left + 1
			if right < n && cmpwhen(self.heap[right].when, self.heap[left].when) == -1 {
				smallest = right
			}

			if cmpwhen(self.heap[i].when, self.heap[smallest].when) <= 0 {
				break
			}

			self.swap(i, smallest)
			i = smallest
		}
	}

	#disable nilptr boundary
	fn swap(mut *self, i: int, j: int) {
		self.heap[i], self.heap[j] = self.heap[j], self.heap[i]
		self.heap[i].index = i
		self.heap[j].index = j
	}

	// Checks the heap, pops, and returns the timer if it is ready to fire.
	// Safely cleans up lazy-deleted timers along the way.
	// The returned timer's lock will be acquired.
	fn check(mut *self, now: i64): (t: &timer, pollUntil: i64) {
		self.mu.lock()
		defer { self.mu.unlock() }

		for {
			if len(self.heap) == 0 {
				return nil, -1
			}

			min := self.heap[0]

			// 1. Lazy Deletion Cleanup
			if atomic::Load(&min.deleted, atomic::Acquire) == -1 {
				self.pop() // Remove the dead timer from the heap and evaluate the next one.
				continue
			}

			// 2. Not time yet
			if min.when > now {
				return nil, min.when - now
			}

			// 3. Time to run, detach from the heap
			t = self.pop()

			// Staying true to the original API design, we hold the lock of the returned
			// timer until the firing process is completed (i.e., until unlockAndFire is called).
			t.mu.lock()
			return t, 0
		}
	}

	// Uses an atomic value to instantly peek at the delay until the next timer.
	fn wakeTime(*self): (pollUntil: i64) {
		return atomic::Load(&self.earliest, atomic::Acquire)
	}
}

// Compares two "when" timestamps w1 and w2 and returns their ordering.
fn cmpwhen(w1: i64, w2: i64): int {
	if w1 < w2 {
		return -1
	}
	if w1 > w2 {
		return +1
	}
	return 0
}

// Result flags of [fire].
const (
	fireInternalTimer = 1 << iota // Internal timer.
	fireCTimer                    // Coroutine-associated timer.
)

// Fires the timer t.
// If t is an internal timer, it invokes its routine immediately and
// returns fireInternalTimer. In this case, cp is not used.
//
// Otherwise, t is either a user timer or a coroutine-wrapped internal timer.
// Such timers are associated with a coroutine; the coroutine state is written
// to cp and fireCTimer is returned. The timer will then be fired when the
// scheduler executes the coroutine referenced by cp.
fn fire(mut t: &timer, mut &cp: *c): int {
	if t.ifunc != nil {
		// This timer is an runtime internal timer associated with
		// a raw function to be invoked when timer fired.
		t.unlockAndFire()
		return fireInternalTimer
	} else {
		// The timer associated with a coroutine,
		// let the scheduler handle this.
		*cp = unsafe { *(*c)(t.arg) }
		t.mu.unlock()
		return fireCTimer
	}
}