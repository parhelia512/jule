use "std/sys"

fn nanotime(): i64 {
	mut ts := sys::Timespec{}
	if unsafe { extern.clock_gettime(extern.clockid_t(sys::CLOCK_MONOTONIC), (*extern.timespec)(&ts)) } == -1 {
		panic("runtime: nanotime failed")
	}
	return i64(ts.Sec)*1e9 + i64(ts.Nsec)
}

fn timeinit() {}