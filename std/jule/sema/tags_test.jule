use "std/jule/ast"
use "std/jule/log"
use "std/jule/mod"
use "std/jule/resource"
use "std/jule/token"
use "std/testing"

struct tagTest {
	lit:  string
	tags: map[string]string
}

let tagTests = []tagTest([
	{
		lit: "`foo:\"bar\"`",
		tags: map[string]string{
			"foo": "bar",
		},
	},
	{
		lit: "`f_oo:\"bar\"`",
		tags: map[string]string{
			"f_oo": "bar",
		},
	},
	{
		lit: "\"foo:\\\"bar\\\"\"",
		tags: map[string]string{
			"foo": "bar",
		},
	},
	{
		lit: "`foo:\"\\u00E7\"`",
		tags: map[string]string{
			"foo": "ç",
		},
	},
	{
		lit: "\"foo:\\\"\\\\u00E7\\\"\"",
		tags: map[string]string{
			"foo": "ç",
		},
	},
	{
		lit: "\"foo:\\\"\\u00E7\\\"\"",
		tags: map[string]string{
			"foo": "ç",
		},
	},
	{
		lit: "`foo:\"bar\" baz:\"foo\"`",
		tags: map[string]string{
			"foo": "bar",
			"baz": "foo",
		},
	},
	{
		lit: "`fo34çöğ;)(9384#o:\"foo\"`",
		tags: map[string]string{
			"fo34çöğ;)(9384#o": "foo",
		},
	},
])

#test
fn testTags(t: &testing::T) {
	mut f := &Field{
		AST: &ast::Field{
			Tag: &token::Token{
				FileSetID: 0,
			},
		},
	}
	mut fs := token::FileSet.New("/jule/sema/test")
	fs.ID = 0
	mut tc := &tagChecker{
		s: &sema{
			importer: &testImporter{
				filesets: [fs],
			},
		},
		f: f,
	}
	for i, test in tagTests {
		f.AST.Tag.Kind = test.lit
		ok := tc.check()
		if !ok {
			t.Errorf("#{} checking failed", i)
			continue
		}
		if len(f.Tags) != len(test.tags) {
			t.Errorf("#{} f.Tags != test.tags, expected {}, found {}", i, test.tags, f.Tags)
			continue
		}
		for k, v in test.tags {
			v2, exist := f.Tags[k]
			if !exist || v != v2 {
				t.Errorf("#{} f.Tags != test.tags, expected {}, found {}", i, test.tags, f.Tags)
				break
			}
		}
	}
}

struct testImporter {
	filesets: []&token::FileSet
}

impl Importer for testImporter {
	fn GetFileSet(mut *self, id: int): &token::FileSet {
		if id == token::InvalidID || id < 0 || len(self.filesets) <= id {
			return nil
		}
		return self.filesets[id]
	}

	fn HasTag(mut *self, tag: string): bool {
		panic("unimplemented")
