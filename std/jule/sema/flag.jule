// A commonf flagset for sema.
// May contain internal flags of semantic analysis.
type Flag: uint

// Flags for Flag.
const (
	F_USED = 1 << iota
	F_VARIADIC
	F_GENERIC
	F_MUTABLE
	F_COMPARABLE
	F_HAS_DEFER
	F_ANON
	F_AS_ANON
	F_CALLED_CO
	F_IOTA
	F_CONST
	F_TYPE

	// Internal sema flags.
	// This flags may be passed without documentation.
	F_CHECKED
	F_RELOADED
	F_ONELINER
)