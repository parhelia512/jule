use "std/jule/ast"
use "std/jule/build"
use "std/jule/log"
use "std/jule/mod"
use "std/unsafe"

// Flags for semantic analysis.
const (
	Default   = 1 << iota // Default semantic analysis of Jule.
	Shadowing             // Default + enable shadowing.
)

// Builds symbol table of AST.
fn buildSymbols(modID: mod::ID, importPath: string, mut ast: &ast::AST, mut importer: Importer, mut owner: &symBuilder): (&SymTab, []log::Log) {
	mut sb := &symBuilder{
		modID:      modID,
		importPath: importPath,
		ast:        ast,
		importer:   importer,
		owner:      owner,
	}
	sb.build()

	if len(sb.errors) == 0 {
		return sb.table, nil
	}
	return nil, sb.errors
}

// See developer reference (6).
fn collectImplicitImports(mut s: &sema, mut file: &SymTab) {
	for (_, mut imp) in file.Imports {
		if !isImplicitImport(imp) {
			break
		}
		match imp.LinkPath {
		| "std/runtime":
			s.meta.runtime = imp
		| "std/internal/runtime/builtin":
			// no-op
		|:
			panic("sema: implementation mistake in implicit import collection, this panic call should be unreachable")
		}
	}
}

// Constraints:
//	- len(files) > 0
fn analyzePackage(mut files: []&ast::AST, mut importer: Importer, flags: int): (&Package, []log::Log) {
	// Select import path for the main package.
	// If there is no importer, use fileset path as import path.
	// If we have importer, use the main package path as import path.
	mut importPath := ""

	// Select module ID for the main package.
	// If there is no module, use invalid ID as module path.
	// If we have a module, use the module path.
	mut modID := mod::InvalidID

	if importer != nil {
		mod := importer.GetMod()
		if mod != nil {
			modID = mod.ID
		}
		importPath = importer.GetMainPackagePath()
	}
	if importPath == "" {
		importPath = files[0].File.Dir()
	}

	// Build symbol tables of files.
	mut tables := make([]&SymTab, 0, len(files))
	for (_, mut f) in files {
		mut table, mut errors := buildSymbols(modID, importPath, f, importer, nil)
		if len(errors) > 0 {
			return nil, errors
		}
		tables = append(tables, table)
	}

	// Allocate meta on stack to avoid heap allocation.
	// It also drops allocation references when scope ends.
	// sema instances will not use meta after this function ends.
	let mut meta: commonSemaMeta

	mut sema := &sema{
		files:    tables,
		flags:    flags,
		meta:     unsafe { (&commonSemaMeta)(&meta) },
		importer: importer,
	}

	// Use first table (so first file) for this.
	// See developer reference (6).
	mut firstTable := tables[0]
	collectImplicitImports(sema, firstTable)

	sema.setSemaFields()
	if importer != nil {
		ok := sema.checkPackages(importer.AllPackages())
		if !ok {
			return nil, meta.errors
		}
	}
	sema.check()
	if len(meta.errors) > 0 {
		return nil, meta.errors
	}

	mut pkg := &Package{
		Files: sema.files,
	}

	return pkg, nil
}

// Builds symbol table of package's ASTs.
// Returns nil if files is nil.
// Returns nil if pwd is empty.
// Returns nil if pstd is empty.
// Accepts current working directory is pwd.
//
// Parameters:
//	files:    abstract syntax trees of files
//	importer: importer that used for use declarations
//
// Dependent Parameters:
//	working-directory: uses working directory path provided by build
//	std-path:          uses standard library path provided by build
//
// Constraints:
//	- importer's main package path should be set.
//	- importer's module must be point to the package's module, if exist.
//
// Risks:
//	You can pass nil to importer, but panics if importer is nil and
//	semantic analyzer used nil importer.
fn AnalyzePackage(mut files: []&ast::AST, mut importer: Importer, flags: int): (&Package, []log::Log) {
	if len(files) == 0 {
		return nil, nil
	}
	return analyzePackage(files, importer, flags)
}

// Same as [AnalyzePackage], but it takes a singe file.
fn AnalyzeFile(mut f: &ast::AST, mut importer: Importer, flags: int): (&SymTab, []log::Log) {
	let mut files: [1]&ast::AST = [f]
	mut _files := unsafe::Slice(&files[0], len(files), len(files))
	mut pkg, mut errors := AnalyzePackage(_files, importer, flags)
	if len(errors) > 0 {
		return nil, errors
	}
	// Select first table, because package has only one file.
	// We give just one file.
	mut table := pkg.Files[0]
	return table, nil
}