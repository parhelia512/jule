// A commonf flagset for AST nodes.
type Flag: uint

// Flags for Flag.
const (
	F_EXTERN: Flag = 1 << iota
	F_CO
	F_AWAIT
	F_MUTABLE
	F_REFERENCE
	F_UNSAFE
	F_DEFER
	F_VARIADIC
	F_PUBLIC
	F_ASYNC
	F_GLOBAL
	F_SHORT
	F_STATIC
	F_FALLIBLE
	F_CONST
	F_STRICT
	F_TYPE
)