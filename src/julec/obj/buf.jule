use "std/conv"
use "std/strings"

fn WriteInt(mut &buf: *strings::Builder, x: i64, fmt: int) {
	unsafe { buf.SetBuf(conv::AppendInt(buf.Buf(), x, fmt)) }
}

fn WriteUint(mut &buf: *strings::Builder, x: u64, fmt: int) {
	unsafe { buf.SetBuf(conv::AppendUint(buf.Buf(), x, fmt)) }
}