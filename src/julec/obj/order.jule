use "std/jule/ast"
use "std/jule/sema"

// Collection for ordered defines.
struct OrderedDefines {
	Structs: []&sema::Struct
	Globals: []&sema::Var
}

// Reports whether type in correct order by dependencies.
fn isOrdered[T](mut importer: sema::Importer, t: &T, s: []&T, partial: bool): bool {
lookup:
	for _, d in t.Depends {
		dAST := d.AST
		const match type T {
		| sema::Var:
			if dAST.Flags&(ast::F_CONST|ast::F_EXTERN) != 0 {
				// Skip constant or external variables for dependency analysis.
				// It is not cost for runtime, so it is not an real-memory dependency.
				continue
			}
		| sema::Struct:
			if dAST.Flags&ast::F_EXTERN != 0 {
				// Skip external structures for dependency analysis.
				// It is not cost for runtime, so it is not an real-memory dependency.
				continue
			}
		}

		if partial {
			dASTFile := importer.GetFileSet(dAST.Token.FileSetID)
			tASTFile := importer.GetFileSet(t.AST.Token.FileSetID)
			if dASTFile.Dir() != tASTFile.Dir() {
				continue
			}
		}

		for _, o in s {
			if d == o {
				continue lookup
			}
		}
		// Dependency is not ordered.
		// All dependencies should be ordered first.
		return false
	}
	return true
}

// Orders defines s by their dependencies.
// All dependencies should came before the referencer after order.
// If partial ordering enabled, it assumes the dependencies from other packages
// should ordered correctly.
fn order[T](mut importer: sema::Importer, mut s: []&T, partial: bool) {
	mut i := 0
repeat:
	mut j := i
iter:
	for j < len(s); j++ {
		mut t := s[j]
		for _, o in s[:i] {
			if t == o {
				// Do not iterate if already iterated and added to ordered list.
				continue iter
			}
		}
		if isOrdered(importer, t, s[:i], partial) {
			if i != j {
				s[i], s[j] = s[j], s[i]
			}
			i++
		}
	}
	if i < len(s) {
		goto repeat
	}
}